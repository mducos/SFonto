sf:LHomme_Bicycle_Work a <http://iflastandards.info/ns/lrm/lrmoo/F1_Work> ;
    rdfs:label "L'Homme-bicycle (work)"@en ;
    dcterms:title "L'Homme-bicycle"@fr ;
    dcterms:alternative "légende pour l'an 1900"@fr ;
    dcterms:creator "Alfred Capus" ;
    dcterms:issued "1893"^^xsd:gYear ;
    <http://www.cidoc-crm.org/cidoc-crm/P2_has_type> sf:type_short_story ;
    <https://w3id.org/golem/ontology#GP0_has_feature> sf:Feature_science_fiction ;
    <https://w3id.org/golem/ontology#GP0_has_feature> sf:Feature_third_person_narrator ;
    <https://w3id.org/golem/ontology#GP0_has_feature> sf:Feature_heterodiegetic_narrator ;
    <https://w3id.org/golem/ontology#GP0_has_feature> sf:Feature_humorous_register ;
    <http://www.ontologydesignpatterns.org/ont/dlp/ExtendedDnS.owl#satisfied_by> sf:Setting_around_1900 ;
    <http://www.ontologydesignpatterns.org/ont/dlp/ExtendedDnS.owl#satisfied_by> sf:Setting_bicycle_society ;
    <http://www.ontologydesignpatterns.org/ont/dlp/ExtendedDnS.owl#d-uses> sf:Syuzhet_LHomme_Bicycle ;
    <http://www.ontologydesignpatterns.org/ont/dlp/ExtendedDnS.owl#d-uses> sf:Fabula_LHomme_Bicycle .

sf:LHomme_Bicycle_Expr_FR a <http://iflastandards.info/ns/lrm/lrmoo/F2_Expression> ;
    rdfs:label "French Expression"@en ;
    dcterms:issued "1893"^^xsd:gYear ;
    <http://www.cidoc-crm.org/cidoc-crm/P2_has_type> sf:type_written_text ;
    <http://iflastandards.info/ns/lrm/lrmoo/R3i_realises> sf:LHomme_Bicycle_Work ;
    dc:language "fr" .

sf:type_short_story a <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
    rdfs:label "Short story" .

sf:Marius a sf:H3_Human_Character, sf:H4_Non-human_Character ;
